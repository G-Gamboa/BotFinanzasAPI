DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/postgres
ENV=development
TZ=America/Guatemala
USD_TO_GTQ=7.7
TELEGRAM_BOT_TOKEN=your_bot_token_here
CORS_ORIGINS=["https://tu-dominio.github.io"]
ADMIN_TELEGRAM_IDS=[123456789]
ADMIN_SECRET=your_admin_secret_here
# IDs con acceso permanente a paletas privadas Y exentos de suscripción
PRIVATE_PALETTE_USER_IDS=[123456789, 987654321]

# Registro con Telegram Stars
# Precio en Stars (100 Stars ≈ $2 USD; Telegram retiene ~30%)
REGISTRATION_STARS_PRICE=100
# Token secreto para verificar que el webhook viene de Telegram
# Genera uno aleatorio: python -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here
